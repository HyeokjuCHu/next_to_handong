{
  "name": "team_project",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node --max-old-space-size=4096 ./node_modules/typescript/bin/tsc -b && node --max-old-space-size=4096 ./node_modules/vite/bin/vite.js build",
    "lint": "node --max-old-space-size=4096 ./node_modules/eslint/bin/eslint.js .",
    "preview": "vite preview",
    "firebase:login": "node --max-old-space-size=4096 ./node_modules/firebase-tools/lib/bin/firebase.js login",
    "deploy": "npm run build && node --max-old-space-size=4096 ./node_modules/firebase-tools/lib/bin/firebase.js deploy --project next-to-handong",
    "deploy:hosting": "npm run build && node --max-old-space-size=4096 ./node_modules/firebase-tools/lib/bin/firebase.js deploy --only hosting --project next-to-handong",
    "deploy:firestore": "node --max-old-space-size=4096 ./node_modules/firebase-tools/lib/bin/firebase.js deploy --only firestore --project next-to-handong"
  },
  "dependencies": {
